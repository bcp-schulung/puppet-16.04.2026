<%- | Integer $port, String $db_host, Integer $db_port, String $db_user, String $db_password, String $db_database, String $frontend_host | -%>
PORT=<%= $port %>
DB_HOST=<%= $db_host %>
DB_PORT=<%= $db_port %>
DB_USER=<%= $db_user %>
DB_PASSWORD=<%= $db_password %>
DB_NAME=<%= $db_database %>
FRONTEND_ORIGIN=http://<%= $frontend_host %>:3000
